[MASTER]
ignore=old_automagician.py,old_commented_automagician.py,oldUnitTests.py,CVS
ignore-patterns=^\.#

[MESSAGES CONTROL]
disable=
    missing-docstring,
    invalid-name,
    fixme,
    duplicate-code,
    cyclic-import,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-lines,
    too-many-instance-attributes,
    too-many-public-methods,
    broad-except,
    protected-access,
    redefined-outer-name,
    unused-argument,
    unused-variable,
    global-statement,
    global-variable-undefined,
    broad-exception-raised,
    bare-except,
    raise-missing-from,
    consider-using-f-string,
    logging-fstring-interpolation,
    logging-not-lazy,
    consider-using-with,
    unspecified-encoding,
    subprocess-run-check,
    no-else-return,
    inconsistent-return-statements,
    pointless-string-statement,
    expression-not-assigned,
    unnecessary-pass,
    unnecessary-lambda,
    unnecessary-comprehension,
    use-dict-literal,
    use-list-literal,
    use-implicit-booleaness-not-comparison,
    use-implicit-booleaness-not-len,
    simplifiable-if-expression,
    no-else-break,
    no-else-continue,
    no-else-raise,
    redefined-builtin,
    arguments-differ,
    signature-differs,
    abstract-method,
    attribute-defined-outside-init,
    super-init-not-called,
    no-member,
    no-name-in-module,
    import-error,
    ungrouped-imports,
    wrong-import-order,
    wrong-import-position,
    wildcard-import,
    unused-import,
    relative-beyond-top-level,
    deprecated-module,
    deprecated-method,
    deprecated-argument,
    deprecated-class,
    deprecated-decorator,
    line-too-long,
    consider-using-from-import,
    consider-using-dict-items,
    possibly-used-before-assignment,
    consider-using-sys-exit,
    useless-return,
    consider-using-enumerate,
    too-many-positional-arguments,
    import-outside-toplevel,
    too-many-nested-blocks,
    missing-final-newline,
